# ==============================================
# TankGuard Environment Variables
# ==============================================
# Copy this file to .env and fill in the values.
# Generate secrets with: openssl rand -base64 48

# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/tankguard?schema=public"

# Auth
NEXTAUTH_SECRET="generate-a-random-64-char-string"
NEXTAUTH_URL="http://localhost:3000"

# Application
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# Stripe (Payments — three-tier plan)
# Live account: acct_1TCHnKCBEqeOZm5B (Saastudio). Tier prices below are
# the live mode IDs; staging should override with test-mode IDs in .env.local.
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_PUBLISHABLE_KEY="pk_live_..."
# TankGuard Essentials  — $99/mo,  1 facility
STRIPE_PRICE_ID_TIER_STARTER="price_1TO2cbCBEqeOZm5BVME6l8g9"
# TankGuard Pro         — $499/mo, up to 10 facilities
STRIPE_PRICE_ID_TIER_GROWTH="price_1TO2ccCBEqeOZm5Bqt6xlXI2"
# TankGuard Enterprise  — $1,499/mo, up to 50 facilities + dedicated lead
STRIPE_PRICE_ID_TIER_SCALE="price_1TO2ccCBEqeOZm5BkQBY8EUl"
# Legacy single-plan price (now ARCHIVED in Stripe). Kept ONLY so existing
# subscriptions on this price continue to bill against it. /api/stripe/checkout/legacy
# uses it for grandfathered re-subscribes; never linked from public checkout.
STRIPE_PRICE_ID="price_1TKeyFCBEqeOZm5BIUBNcVa9"
STRIPE_WEBHOOK_SECRET="whsec_..."

# Email (SMTP — for compliance reminders & overdue alerts)
# NOTE: SAASTUDIO_MAILING_ADDRESS (postal address for CAN-SPAM footer) has been
# temporarily removed pending a real address. Re-add this env var before any
# bulk cold-email send. See scripts/lib/canspam_footer.py in zero-human-studio.
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="your-email@example.com"
SMTP_PASS="your-smtp-password"
FROM_EMAIL="noreply@tankguard.com"

# Internal API Secret (for cron-triggered system routes:
# /api/reminders/process, /api/compliance/snapshots, /api/scraper/*)
API_SECRET="generate-a-random-64-char-string"

# Anthropic API key for the weekly SEO article generator (scripts/generate-seo-article.ts).
# Only required when running `pnpm seo:generate`; not used at runtime.
ANTHROPIC_API_KEY="sk-ant-..."

# AWS S3 (production document storage — local /public/uploads used in dev)
# S3_BUCKET="tankguard-documents"
# S3_REGION="us-east-1"
# S3_ACCESS_KEY="your-access-key"
# S3_SECRET_KEY="your-secret-key"
