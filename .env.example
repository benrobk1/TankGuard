# ==============================================
# TankGuard Environment Variables
# ==============================================
# Copy this file to .env and fill in the values.
# Generate secrets with: openssl rand -base64 48

# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/tankguard?schema=public"

# Auth
NEXTAUTH_SECRET="generate-a-random-64-char-string"
NEXTAUTH_URL="http://localhost:3000"

# Application
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# Stripe (Payments — three-tier plan)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
# New tier price IDs (create these Products/Prices in Stripe dashboard)
STRIPE_PRICE_ID_TIER_STARTER="price_..."   # $99/mo, 1 site
STRIPE_PRICE_ID_TIER_GROWTH="price_..."    # $499/mo, up to 10 sites
STRIPE_PRICE_ID_TIER_SCALE="price_..."     # $1,499/mo, up to 50 sites
# Legacy single-plan price — kept for grandfathered customers only.
# Do not link from public checkout. /api/stripe/checkout/legacy uses it.
STRIPE_PRICE_ID="price_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Email (SMTP — for compliance reminders & overdue alerts)
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="your-email@example.com"
SMTP_PASS="your-smtp-password"
FROM_EMAIL="noreply@tankguard.com"
# CAN-SPAM-required mailing address rendered in every email footer.
# Production sends will THROW if this is unset.
SAASTUDIO_MAILING_ADDRESS="Saastudio LLC, [street], [city], [state] [zip]"

# Internal API Secret (for cron-triggered system routes: /api/reminders/process, /api/compliance/snapshots)
API_SECRET="generate-a-random-64-char-string"

# Anthropic API key for the weekly SEO article generator (scripts/generate-seo-article.ts).
# Only required when running `pnpm seo:generate`; not used at runtime.
ANTHROPIC_API_KEY="sk-ant-..."

# AWS S3 (production document storage — local /public/uploads used in dev)
# S3_BUCKET="tankguard-documents"
# S3_REGION="us-east-1"
# S3_ACCESS_KEY="your-access-key"
# S3_SECRET_KEY="your-secret-key"
